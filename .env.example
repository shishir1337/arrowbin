# Copy to .env.local and fill in to enable real lead emails via Resend.
# Without these, the contact form still works in dev — leads are logged to the
# server console and the form returns success (no email is sent).

# Get a free API key at https://resend.com/api-keys
RESEND_API_KEY=

# The "from" address. Must be a verified domain in Resend, e.g.
# "Arrowbin Website <hello@arrowbin.com>". Defaults to Resend's onboarding sender.
CONTACT_FROM_EMAIL=

# --- Analytics & Search Console (optional) ---
# Google Analytics 4 measurement ID, e.g. "G-XXXXXXXXXX". When set, gtag.js loads
# and a `generate_lead` event fires on each successful contact-form submission.
# Must be NEXT_PUBLIC_ (used in the browser).
NEXT_PUBLIC_GA_ID=G-ZZ3NJCZVMZ

# Google Search Console verification token (the content value of the
# `google-site-verification` meta tag). Renders the verification <meta> in <head>.
GOOGLE_SITE_VERIFICATION=
